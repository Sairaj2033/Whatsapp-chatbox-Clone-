<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your chat </title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h3 style="background-color: #128C7E;margin-right:200px ; border-radius: 10px; height: 25px; color: white;">Edit your chat  : <%=chat._id%> </h3>
  <p style="background-color: #128C7E;margin-right:330px ; border-radius: 10px; height: 25px; color: white; margin-left:2px;" >  This chat was sent from <b><%= chat.from%></b>  to <b><%=chat.to%></b> </p>

    <div >       
 <form  class="frm" method="POST" action="/chats/<%=chat._id%>?_method=PUT" >
    <textarea style="background-color: #f2efea;" name="msg" rows="6" cols="30" > <%= chat.msg %> </textarea>
<button class="inbtn"> Edit it!</button>
    
</form>
    </div>


</body>
</html>